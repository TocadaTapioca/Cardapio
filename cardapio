<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Toca da Tapioca - Cardápio</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;font-family:Arial,Helvetica,sans-serif}
    body{background:#080808;color:#fff}
    header{background:linear-gradient(135deg,#000,#1b0d00,#ff7a00);padding:28px 16px;text-align:center}
    header h1{font-size:34px;font-weight:900}
    header span{color:#ff8a00}
    header p{color:#ffe0bd;margin-top:8px}
    .container{max-width:1100px;margin:auto;padding:16px}
    input,select{width:100%;padding:13px;margin:7px 0;border-radius:10px;border:1px solid #444;background:#1b1b1b;color:white;font-size:15px}
    .section-title{color:#ff8a00;margin:24px 0 12px;border-bottom:2px solid #ff8a00;padding-bottom:8px}
    .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px}
    .card{background:#151515;border:1px solid #333;border-radius:16px;padding:15px}
    .card h3{font-size:18px;margin-bottom:8px}
    .card p{color:#ccc;font-size:14px;line-height:1.35;min-height:50px}
    .price{color:#00d26a;font-weight:900;font-size:20px;margin:12px 0}
    .row{display:flex;gap:8px;align-items:center}
    .qty{width:58px;text-align:center}
    button{cursor:pointer;border:0;border-radius:10px;padding:11px 13px;font-weight:900}
    .add{background:#ff8a00;color:#000}
    .cart{position:sticky;bottom:0;background:#101010;border-top:2px solid #ff8a00;padding:16px;margin-top:30px;box-shadow:0 -8px 25px rgba(0,0,0,.45)}
    .cart h2{color:#ff8a00;margin-bottom:10px}
    .cart-item{display:flex;justify-content:space-between;gap:8px;border-bottom:1px solid #333;padding:9px 0;font-size:14px}
    .remove{background:#333;color:white;padding:5px 8px;font-size:12px}
    .total{font-size:24px;color:#00d26a;font-weight:900;margin:14px 0}
    .whats{display:block;text-align:center;background:#25d366;color:#fff;text-decoration:none;font-weight:900;border-radius:14px;padding:15px;font-size:18px}
    .clear{background:#333;color:#fff;margin-top:10px;width:100%}
    .small{font-size:12px;color:#aaa;text-align:center;margin-top:8px}
  </style>
</head>
<body>

<header>
  <h1>TOCA DA <span>TAPIOCA</span></h1>
  <p>Sabor que abraça, qualidade que vicia!</p>
</header>

<main class="container">
  <input id="nome" placeholder="Seu nome">
  <input id="endereco" placeholder="Endereço para entrega">
  <select id="pagamento">
    <option value="">Escolha a forma de pagamento</option>
    <option value="PIX">PIX</option>
    <option value="Cartão de Débito">Cartão de Débito</option>
    <option value="Cartão de Crédito">Cartão de Crédito</option>
  </select>
  <input id="troco" placeholder="Troco para quanto? (se precisar)">
  <input id="obs" placeholder="Observação do pedido (opcional)">

  <h2 class="section-title">Tapiocas Salgadas</h2>
  <div class="grid" id="salgadas"></div>

  <h2 class="section-title">Tapiocas Doces</h2>
  <div class="grid" id="doces"></div>

  <h2 class="section-title">Bebidas</h2>
  <div class="grid" id="bebidas"></div>

  <h2 class="section-title">Combos</h2>
  <div class="grid" id="combos"></div>

  <section class="cart">
    <h2>🛒 Seu pedido</h2>
    <div id="cartItems"></div>
    <div class="total" id="total">Total: R$ 0,00</div>
    <a id="whatsapp" class="whats" href="#" target="_blank">Enviar pedido no WhatsApp</a>
    <button class="clear" onclick="clearCart()">Limpar pedido</button>
    <p class="small">Seu pedido vai direto para o WhatsApp da loja.</p>
  </section>
</main>

<script>
const phone = '5521999709049';

const items = {
  salgadas: [
    ['Tapioca Explosão de Frango','Frango desfiado + Catupiry + bacon',21.90],
    ['Tapioca Cremosa de Calabresa','Calabresa + queijo + requeijão',21.25],
    ['Tapioca Carne Seca','Carne seca desfiada + queijo coalho',25.40],
    ['Clássica Mista','Presunto + queijo + orégano',16.90],
    ['Frango Fit','Frango + milho + ovo',20.30],
    ['Queijo Top','Queijo minas + orégano',18.70],
    ['Tapioca Leve Cremosa','Peito de peru + Catupiry + mussarela + orégano',20.80],
    ['Peito de Peru Especial da Casa','Peito de peru + queijo minas + orégano',20.40],
    ['Tapioca Sabor Pizza','Mussarela + calabresa + tomate + orégano',21.20],
    ['Carne Seca Cremosa','Carne seca desfiada + Catupiry',24.60],
    ['Camarão Cremoso Premium','Camarões suculentos + Catupiry',29.70]
  ],
  doces: [
    ['Nutella com Morango','Tapioca recheada com Nutella e morangos frescos',24.60],
    ['Beijinho da Toca','Leite condensado + coco',17.00],
    ['Romeu e Julieta','Queijo minas + goiabada',18.70],
    ['Banana Supreme','Nutella cremosa + banana doce',22.00],
    ['Prestígio da Toca','Nutella derretida + coco',23.70],
    ['Ninho com Nutella Supreme','Brigadeiro de Ninho + Nutella + leite em pó',25.40]
  ],
  bebidas: [
    ['Coca-Cola Lata 350ml','Refrigerante lata',6.00],
    ['Guaraná Antarctica Lata 350ml','Refrigerante lata',6.00],
    ['GuaraCrac Original 290ml','Copo 290ml',2.00],
    ['Coca-Cola Garrafa 200ml','Garrafinha 200ml',3.50]
  ],
  combos: [
    ['Combo Solteiro Explosão','1 Tapioca Explosão de Frango + uma bebida gelada',25.10],
    ['Combo Clássico','1 Clássica Mista + uma bebida gelada',21.25],
    ['Combo Casal da Toca','Escolha 2 tapiocas bem recheadas + 2 bebidas geladinhas',57.50],
    ['Combo Família da Toca','Escolha 4 tapiocas bem recheadas + 4 bebidas geladinhas',102.00]
  ]
};

let cart = [];

function money(v){
  return v.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});
}

function renderSection(key){
  const el = document.getElementById(key);
  items[key].forEach((it,i)=>{
    const id = key+i;
    el.innerHTML += `
      <div class="card">
        <h3>${it[0]}</h3>
        <p>${it[1]}</p>
        <div class="price">${money(it[2])}</div>
        <div class="row">
          <input class="qty" type="number" id="${id}" min="1" value="1">
          <button class="add" onclick="addItem('${key}',${i},'${id}')">Adicionar</button>
        </div>
      </div>`;
  });
}

function addItem(key,i,id){
  const q = parseInt(document.getElementById(id).value || 1);
  const [name,desc,price] = items[key][i];
  cart.push({name, price, qty:q});
  renderCart();
}

function removeItem(i){
  cart.splice(i,1);
  renderCart();
}

function renderCart(){
  const box = document.getElementById('cartItems');
  box.innerHTML = '';
  let total = 0;

  cart.forEach((c,i)=>{
    total += c.price * c.qty;
    box.innerHTML += `
      <div class="cart-item">
        <span>${c.qty}x ${c.name}</span>
        <span><strong>${money(c.price*c.qty)}</strong> <button class="remove" onclick="removeItem(${i})">X</button></span>
      </div>`;
  });

  document.getElementById('total').innerText = 'Total: ' + money(total);

  const nome = document.getElementById('nome').value;
  const endereco = document.getElementById('endereco').value;
  const pagamento = document.getElementById('pagamento').value;
  const troco = document.getElementById('troco').value;
  const obs = document.getElementById('obs').value;

  let msg = `Olá, Toca da Tapioca! Quero fazer um pedido:%0A%0A`;
  if(nome) msg += `Nome: ${nome}%0A`;
  if(endereco) msg += `Endereço: ${endereco}%0A`;
  if(pagamento) msg += `Forma de pagamento: ${pagamento}%0A`;
  if(troco) msg += `Troco para: ${troco}%0A`;

  msg += `%0AItens:%0A`;
  cart.forEach(c => msg += `- ${c.qty}x ${c.name} = ${money(c.price*c.qty)}%0A`);
  msg += `%0ATotal: ${money(total)}%0A`;
  if(obs) msg += `Observação: ${obs}%0A`;

  document.getElementById('whatsapp').href = `https://wa.me/${phone}?text=${msg}`;
}

function clearCart(){
  cart = [];
  renderCart();
}

['salgadas','doces','bebidas','combos'].forEach(renderSection);
['nome','endereco','pagamento','troco','obs'].forEach(id=>{
  document.getElementById(id).addEventListener('input', renderCart);
});
renderCart();
</script>

</body>
</html>

